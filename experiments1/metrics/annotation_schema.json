{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Document Annotation Schema",
  "description": "Schema for ground truth document annotations for evaluation",
  "type": "object",
  "properties": {
    "document_id": {
      "type": "string",
      "description": "Unique identifier for the document"
    },
    "source_file": {
      "type": "string",
      "description": "Path to the original source file"
    },
    "document_format": {
      "type": "string",
      "enum": ["pdf", "docx", "pdf_scanned"],
      "description": "Format of the document"
    },
    "annotation_version": {
      "type": "string",
      "description": "Version of annotation schema"
    },
    "annotator": {
      "type": "string",
      "description": "Name of the annotator"
    },
    "annotation_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of annotation"
    },
    "elements": {
      "type": "array",
      "description": "List of annotated elements in document order",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique element identifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "title", "header_1", "header_2", "header_3", "header_4", "header_5", "header_6",
              "text", "image", "table", "formula", "list_item", "caption", "footnote",
              "page_header", "page_footer", "link", "code_block"
            ],
            "description": "Element type"
          },
          "content": {
            "type": "string",
            "description": "Element content (text, markdown, etc.)"
          },
          "parent_id": {
            "type": ["string", "null"],
            "description": "Parent element ID for hierarchy (null for root elements)"
          },
          "order": {
            "type": "integer",
            "description": "Sequential order of element in document (0-based or 1-based)"
          },
          "page_number": {
            "type": ["integer", "null"],
            "description": "Page number where element appears (1-based)"
          },
          "bbox": {
            "type": ["array", "null"],
            "description": "Bounding box [x0, y0, x1, y1] in document coordinates",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata",
            "properties": {
              "table_structure": {
                "type": "object",
                "description": "Table structure for TEDS evaluation (only for table elements)",
                "properties": {
                  "html": {
                    "type": "string",
                    "description": "HTML representation of table structure"
                  },
                  "cells": {
                    "type": "array",
                    "description": "List of table cells with their positions",
                    "items": {
                      "type": "object",
                      "properties": {
                        "row": {"type": "integer"},
                        "col": {"type": "integer"},
                        "rowspan": {"type": "integer", "default": 1},
                        "colspan": {"type": "integer", "default": 1},
                        "content": {"type": "string"}
                      },
                      "required": ["row", "col", "content"]
                    }
                  }
                }
              },
              "image_data": {
                "type": "string",
                "description": "Base64 encoded image data with data URL prefix (data:image/{format};base64,{base64_string})"
              },
              "image_format": {
                "type": "string",
                "enum": ["png", "jpeg", "jpg"],
                "description": "Image format (png, jpeg, jpg)"
              },
              "image_width": {
                "type": "integer",
                "description": "Image width in pixels"
              },
              "image_height": {
                "type": "integer",
                "description": "Image height in pixels"
              },
              "links": {
                "type": "array",
                "description": "List of URLs found in element",
                "items": {"type": "string"}
              }
            }
          }
        },
        "required": ["id", "type", "content", "order"]
      }
    },
    "statistics": {
      "type": "object",
      "description": "Document statistics for validation",
      "properties": {
        "total_elements": {"type": "integer"},
        "total_pages": {"type": "integer"},
        "elements_by_type": {
          "type": "object",
          "description": "Count of elements by type"
        },
        "table_count": {"type": "integer"},
        "image_count": {"type": "integer"}
      }
    }
  },
  "required": ["document_id", "source_file", "document_format", "elements"]
}
