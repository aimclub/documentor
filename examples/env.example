# Documentor Environment Configuration
# Copy this file to .env and fill in your actual values

# Dots.OCR API Configuration (REQUIRED)
DOTS_OCR_BASE_URL=
DOTS_OCR_API_KEY=
DOTS_OCR_MODEL_NAME=/model
DOTS_OCR_TASK_FORMAT=Layout

# Dots.OCR Optional Parameters
DOTS_OCR_TEMPERATURE=0.1
DOTS_OCR_MAX_TOKENS=32768
DOTS_OCR_TIMEOUT=120

# Development/Debug Settings
LOG_LEVEL=INFO
DEBUG=false
